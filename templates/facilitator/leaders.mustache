{{!
    @template mod_kahoodle/facilitator/leaders

    Leaderboard stage template - shown after question results.

    Context variables required for this template:
    * quiztitle - The title of the quiz/kahoodle activity
    * currentquestion - Current question number
    * totalquestions - Total number of questions in the round
    * cancontrol - Boolean indicating if user can control the quiz (teacher)
    * isedit - Boolean indicating if it is rendered for teachers when they edit the questions
    * backgroundurl - URL for background image
    * leaders - Array of leader objects (placeholder for now)

    Example context (json):
    {
        "quiztitle": "Geography & World Facts Quiz",
        "currentquestion": 3,
        "totalquestions": 10,
        "cancontrol": true,
        "isedit": false,
        "backgroundurl": "/mod/kahoodle/pix/classroom-bg.jpg",
        "leaders": []
    }
}}
<div class="mod_kahoodle-overlay" {{#backgroundurl}}style="background-image: url('{{backgroundurl}}');"{{/backgroundurl}}>

    {{> mod_kahoodle/facilitator/common/questionheader }}

    <main class="mod_kahoodle-main mod_kahoodle-leaders" data-stage="leaders">

        <h1 class="mod_kahoodle-leaderboard-title">{{#str}}leaderboard, mod_kahoodle{{/str}}</h1>

        {{> mod_kahoodle/facilitator/common/leaderboard }}

        {{#statusmessage}}
        <div class="mod_kahoodle-leaderboard-status">
            {{{statusmessage}}}
        </div>
        {{/statusmessage}}

    </main>

    {{> mod_kahoodle/facilitator/common/footer }}

</div>
