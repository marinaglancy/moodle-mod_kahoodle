{{!
    @template mod_kahoodle/facilitator/revision

    Shown on facilitator screens during the revision stage (final leaderboard).

    Example context (json):
    {
    }
}}
<div class="mod_kahoodle-overlay" {{#backgroundurl}}style="background-image: url('{{backgroundurl}}');"{{/backgroundurl}}>

    <main class="mod_kahoodle-main mod_kahoodle-leaders" data-stage="revision">

        <div class="mod_kahoodle-leaders-content">
            <h1 class="mod_kahoodle-leaders-title">Final leaderboard</h1>
            <p class="mod_kahoodle-leaders-placeholder">Final leaderboard will be displayed here</p>
        </div>

    </main>

    {{> mod_kahoodle/facilitator/common/footer }}

</div>
