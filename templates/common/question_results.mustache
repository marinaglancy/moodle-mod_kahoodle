{{!
    @template mod_kahoodle/common/question_results

    Question results display showing answer distribution bar chart.

    Context variables required for this template:
    * quiztitle - The title of the quiz/kahoodle activity
    * sortorder - Current question number
    * totalquestions - Total number of questions in the round
    * questiontextcompact - The question text (compact version for results)
    * questiontype - Question type identifier (e.g., "multichoice")
    * typeismultichoice - Boolean true if questiontype is "multichoice" (added by JS)
    * typedata - Object containing type-specific data (decoded from JSON by JS)
    * cancontrol - Boolean indicating if user can control the quiz (teacher)
    * isedit - Boolean indicating if it is rendered for teachers when they edit the questions
    * backgroundurl - URL for background image (optional)

    For multichoice questions, typedata contains:
    * options - Array of answer options with iscorrect flag
    * bars - Array of bar chart data

    Example context (json):
    {
        "quiztitle": "Geography & World Facts Quiz",
        "sortorder": 36,
        "totalquestions": 42,
        "questiontextcompact": "How long would it take to walk around the world's perimeter?",
        "questiontype": "multichoice",
        "typeismultichoice": true,
        "typedata": {
        },
        "cancontrol": true
    }
}}
<div class="mod_kahoodle-overlay" {{#backgroundurl}}style="background-image: url('{{backgroundurl}}');"{{/backgroundurl}}>

    {{> mod_kahoodle/common/header }}

    {{! Main content: Question, bar chart, and options }}
    <main class="mod_kahoodle-main" data-stage="results" data-questiontype="{{questiontype}}">

        {{! Question text (compact) }}
        <div class="mod_kahoodle-question">
            <h1 class="mod_kahoodle-question-text">{{{questiontextcompact}}}</h1>
        </div>

        {{! Question type specific content }}
        {{$ question_type_contents }}
        {{/ question_type_contents }}

    </main>

    {{> mod_kahoodle/common/footer }}

</div>
