{{!
    @template mod_kahoodle/questiontypes/multichoice/question_results

    Multichoice question type partial for question results display.

    Context variables required for this template (from typedata):
    * options - Array of answer options, each containing:
        * optionnumber - The option number (1-8)
        * letter - The letter label (A, B, C, etc.)
        * text - The option text
        * iscorrect - Boolean indicating if this is the correct answer
    * bars - Array of bar chart data, each containing:
        * optionnumber - The option number (1-8)
        * letter - The letter label (A, B, C, etc.)
        * count - Number of responses for this option
        * heightpercent - Bar height as percentage (0-100)
        * iscorrect - Boolean indicating if this is the correct answer
        * isshort - Boolean indicating if bar is too short to display count inside (heightpercent < 25)

    Example context (json):
    {
        "quiztitle": "Geography & World Facts Quiz",
        "sortorder": 36,
        "totalquestions": 42,
        "questiontext": "How long would it take to walk around the world's perimeter?",
        "questiontextcompact": "How long would it take to walk around the world's perimeter?",
        "questiontype": "multichoice",
        "typeismultichoice": true,
        "typedata": {
            "options": [
                {"optionnumber": 1, "letter": "A", "text": "5 days", "iscorrect": false, "count": 3, "heightpercent": 19},
                {"optionnumber": 2, "letter": "B", "text": "50 days", "iscorrect": false, "count": 8, "heightpercent": 50},
                {"optionnumber": 3, "letter": "C", "text": "200 days", "iscorrect": false, "count": 5, "heightpercent": 31},
                {"optionnumber": 4, "letter": "D", "text": "You cannot walk around the world, there is an ocean", "iscorrect": true, "count": 16, "heightpercent": 100}
            ]
        },
        "cancontrol": true
    }
}}
{{< mod_kahoodle/common/question_results }}
{{$ question_type_contents }}
{{#typedata}}
{{! Results bar chart }}
<div class="mod_kahoodle-results-chart">
    <div class="mod_kahoodle-chart-bars">
        {{#options}}
        <div class="mod_kahoodle-chart-bar-wrapper{{#iscorrect}} mod_kahoodle-bar-correct{{/iscorrect}}{{#isshort}} mod_kahoodle-bar-short{{/isshort}}">
            <div class="mod_kahoodle-chart-bar-container">
                <div class="mod_kahoodle-chart-bar mod_kahoodle-bar-option{{optionnumber}}" style="height: {{heightpercent}}%;">
                    <span class="mod_kahoodle-bar-count-above">{{count}}</span>
                    <span class="mod_kahoodle-bar-count">{{count}}</span>
                    {{#iscorrect}}
                    <span class="mod_kahoodle-correct-badge">✓</span>
                    {{/iscorrect}}
                </div>
            </div>
            <div class="mod_kahoodle-bar-label mod_kahoodle-bar-label-option{{optionnumber}}">{{letter}}</div>
        </div>
        {{/options}}
    </div>
</div>

{{! Answer options }}
<div class="mod_kahoodle-options{{#manyoptions}} mod_kahoodle-options-many{{/manyoptions}}">
    <div class="mod_kahoodle-options-grid{{#manyoptions}} mod_kahoodle-options-grid-compact{{/manyoptions}}">
        {{#options}}
        <div class="mod_kahoodle-option mod_kahoodle-option{{optionnumber}}{{#iscorrect}} mod_kahoodle-option-correct{{/iscorrect}}" data-option="{{optionnumber}}">
            <div class="mod_kahoodle-option-icon">
                <span class="mod_kahoodle-icon-letter">{{letter}}</span>
            </div>
            <span class="mod_kahoodle-option-text">{{text}}</span>
            {{#iscorrect}}
            <span class="mod_kahoodle-correct-indicator">✓</span>
            {{/iscorrect}}
        </div>
        {{/options}}
    </div>
</div>
{{/typedata}}
{{/ question_type_contents }}
{{/ mod_kahoodle/common/question_results }}