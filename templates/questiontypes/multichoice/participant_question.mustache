{{!
    @template mod_kahoodle/questiontypes/multichoice/participant_question

    Shown to participants for multiple choice questions during the question stage.

    Example context (json):
    {
        "answered": false,
        "avatarurl": "/user/pix.php/2/f1.jpg",
        "displayname": "Alex Johnson",
        "totalscore": 150,
        "typedata": {
            "manyoptions": true,
            "options": [
                {
                    "optionnumber": 1,
                    "letter": "A"
                },
                {
                    "optionnumber": 2,
                    "letter": "B"
                },
                {
                    "optionnumber": 3,
                    "letter": "C"
                },
                {
                    "optionnumber": 4,
                    "letter": "D"
                },
                {
                    "optionnumber": 5,
                    "letter": "E"
                },
                {
                    "optionnumber": 6,
                    "letter": "F"
                },
                {
                    "optionnumber": 7,
                    "letter": "G"
                },
                {
                    "optionnumber": 8,
                    "letter": "H"
                }
            ]
        }
    }
}}
{{< mod_kahoodle/participant/common/base }}
{{$ main_content }}
{{> mod_kahoodle/participant/common/questionheader }}

<div class="mod_kahoodle-participant-result-content">
    {{^answered}}

    {{! Question type specific content - answer options }}
    {{#typedata}}
    <div class="mod_kahoodle-options{{#manyoptions}} mod_kahoodle-options-many{{/manyoptions}}">
        <div class="mod_kahoodle-options-grid{{#manyoptions}} mod_kahoodle-options-grid-compact{{/manyoptions}}">
            {{#options}}
            <div class="mod_kahoodle-option mod_kahoodle-option{{optionnumber}}" data-option="{{optionnumber}}">
                <div class="mod_kahoodle-option-icon">
                    <span class="mod_kahoodle-icon-letter">{{letter}}</span>
                </div>
            </div>
            {{/options}}
        </div>
    </div>
    {{/typedata}}

    {{/answered}}

    {{#answered}}
    {{! TODO this is incorrect, should be some waiting state without green tick or "good job" because it can be wrong }}
    <div class="mod_kahoodle-participant-result-status">{{#str}}goodjob, mod_kahoodle{{/str}}</div>
    <div class="mod_kahoodle-participant-result-icon mod_kahoodle-result-answered">
        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
    </div>
    <div class="mod_kahoodle-participant-result-rank">{{#str}}waitingforresults, mod_kahoodle{{/str}}</div>
    {{/answered}}
</div>

{{> mod_kahoodle/participant/common/participantinfo }}
{{/ main_content }}
{{/ mod_kahoodle/participant/common/base }}

{{#js}}
require(['core/pubsub'], function(PubSub) {
    document.querySelectorAll('.mod_kahoodle-option[data-option]').forEach(function(el) {
        el.addEventListener('click', function(e) {
            e.preventDefault();
            if (this.classList.contains('mod_kahoodle-option-disabled')) {
                // Already answered.
                return;
            }
            // Visual feedback - disable all options.
            document.querySelectorAll('.mod_kahoodle-option').forEach(function(opt) {
                opt.classList.add('mod_kahoodle-option-disabled');
            });
            this.classList.add('mod_kahoodle-option-selected');
            // Dispatch event for participant.js to catch.
            PubSub.publish('mod_kahoodle:answer', String(this.dataset.option));
        });
    });
});
{{/js}}
