{{!
    @template mod_kahoodle/participant/lobby

    Participant lobby template - shown while waiting for the activity to start.

    Context variables required for this template:
    * activityname - The name of the kahoodle activity
    * avatarurl - URL for the participant's avatar image
    * displayname - The participant's display name
    Example context (json):
    {
        "quiztitle": "Geography Challenge",
        "avatarurl": "/user/pix.php/2/f1.jpg",
        "displayname": "Alex Johnson"
    }
}}
{{< mod_kahoodle/participant/common/base }}
    {{$ main_content }}

            {{! Activity Name }}
            <div class="mod_kahoodle-participant-header">
                <h1 class="mod_kahoodle-participant-activity">{{{quiztitle}}}</h1>
                <a href="#" class="mod_kahoodle-participant-close" data-action="close" aria-label="{{#str}}close, mod_kahoodle{{/str}}">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </a>
            </div>

            {{! Main Content }}
            <div class="mod_kahoodle-participant-content" data-stage="lobby">
                <p class="mod_kahoodle-participant-joining-text">{{#str}}joiningas, mod_kahoodle{{/str}}</p>

                {{! Avatar Section }}
                <div class="mod_kahoodle-participant-avatar-wrapper">
                    <div class="mod_kahoodle-participant-avatar-circle">
                        <img src="{{avatarurl}}" alt="" class="mod_kahoodle-participant-avatar-img">
                    </div>
                    {{#caneditavatar}}
                    <button class="mod_kahoodle-participant-edit-btn" aria-label="{{#str}}editavatar, mod_kahoodle{{/str}}" data-action="editavatar">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path>
                        </svg>
                    </button>
                    {{/caneditavatar}}
                </div>

                {{! Display Name }}
                <p class="mod_kahoodle-participant-display-name">{{{displayname}}}</p>

                {{! Avatar Picker Overlay (hidden by default) }}
                {{#caneditavatar}}
                <div class="mod_kahoodle-avatar-picker" data-region="avatar-picker" style="display: none;">
                    <div class="mod_kahoodle-avatar-picker-header">
                        <h2 class="mod_kahoodle-avatar-picker-title">{{#str}}chooseavatar, mod_kahoodle{{/str}}</h2>
                        <button class="mod_kahoodle-avatar-picker-close" data-action="closepicker" aria-label="{{#str}}close, mod_kahoodle{{/str}}">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                <line x1="6" y1="6" x2="18" y2="18"></line>
                            </svg>
                        </button>
                    </div>
                    <div class="mod_kahoodle-avatar-picker-grid" data-region="avatar-grid">
                        {{! Candidates will be inserted here by JS }}
                    </div>
                    <button class="mod_kahoodle-avatar-picker-more" data-action="showmore" style="display: none;">
                        {{#str}}showmore, mod_kahoodle{{/str}}
                    </button>
                </div>
                {{/caneditavatar}}
            </div>

            {{! Footer Status }}
            <div class="mod_kahoodle-participant-footer">
                <div class="mod_kahoodle-participant-status">
                    <div class="mod_kahoodle-participant-spinner"></div>
                    <span>{{#str}}startingsoonpleasewait, mod_kahoodle{{/str}}</span>
                </div>
            </div>
    {{/ main_content }}
{{/ mod_kahoodle/participant/common/base }}

{{#caneditavatar}}
{{#js}}
require(['mod_kahoodle/participant'], function(participant) {
    participant.initAvatarPicker();
});
{{/js}}
{{/caneditavatar}}
