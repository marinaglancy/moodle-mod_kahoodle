{{!
    @template mod_kahoodle/participant/connectionlost

    Shown to participants when the realtime connection is lost.

    Example context (json):
    {}
}}
{{< mod_kahoodle/participant/common/base }}
{{$ main_content }}

<div class="mod_kahoodle-participant-result-header">
    <div></div>
    <a href="#" class="mod_kahoodle-participant-close" data-action="close"
       aria-label="{{#str}}close, mod_kahoodle{{/str}}">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </a>
</div>

<div class="mod_kahoodle-participant-result-content">
    <div class="mod_kahoodle-participant-result-status">{{#str}}error_connectionlost_title, mod_kahoodle{{/str}}</div>
    <div class="mod_kahoodle-participant-icon mod_kahoodle-result-connectionlost">
        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
    </div>
    <div class="mod_kahoodle-participant-rank">{{#str}}error_connectionlost, mod_kahoodle{{/str}}</div>
    <button class="mod_kahoodle-connectionlost-refresh" data-action="refresh">
        {{#str}}refresh, mod_kahoodle{{/str}}
    </button>
</div>

{{/ main_content }}
{{/ mod_kahoodle/participant/common/base }}
