{{!
    @template mod_kahoodle/participant/common/questionheader

    Header bar for participant screens showing question number and close button.

    Context variables:
    * sortorder - Current question number
    * closeurl - URL to close/exit the quiz (optional)

    Example context (json):
    {
        "sortorder": 36,
        "closeurl": "#"
    }
}}
<div class="mod_kahoodle-participant-result-header">
    <div class="mod_kahoodle-participant-question-pill">{{sortorder}}</div>
    <a href="{{closeurl}}" class="mod_kahoodle-participant-close" data-action="close" aria-label="{{#str}}close, mod_kahoodle{{/str}}">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </a>
</div>
