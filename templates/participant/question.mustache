{{!
    @template mod_kahoodle/participant/question

    Shown to participants during the question stage.

    Example context (json):
    {
        "answered": true
    }
}}
{{< mod_kahoodle/participant/common/base }}
{{$ main_content }}
{{^answered}}
        {{! Question type specific content }}
        {{$ question_type_contents }}
        {{/ question_type_contents }}
{{/answered}}
{{#answered}}
    <div>
    Quick answer!
    </div>

    <div>
    Wait for the results...
    </div>
{{/answered}}
{{/ main_content }}
{{/ mod_kahoodle/participant/common/base }}
