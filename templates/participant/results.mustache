{{!
    @template mod_kahoodle/participant/results

    Shown to participants during the results and leaders stages.

    Example context (json):
    {
        "timeup": false,
        "correct": true,
        "rank": 3,
        "rankstatus": "13 points behind John",
        "sortorder": 1
    }
}}
{{< mod_kahoodle/participant/common/base }}
{{$ main_content }}
<div>TODO results placeholder</div>
<div>
    Question {{sortorder}}
</div>
    {{#timeup}}
        <div>Time is up!</div>
    {{/timeup}}
    {{^timeup}}
        {{#correct}}
            <div>Correct!</div>
        {{/correct}}
        {{^correct}}
            <div>Incorrect</div>
        {{/correct}}
    {{/timeup}}

    <div>You're in {{rank}} place</div>

    <div>{{{rankstatus}}}</div>
{{/ main_content }}
{{/ mod_kahoodle/participant/common/base }}