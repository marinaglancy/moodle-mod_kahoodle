{{!
    @template mod_kahoodle/participant/revision

    Shown to participants during the revision stage (final leaderboard).

    Context variables:
    * quiztitle - The quiz/activity title
    * rank - Final rank position
    * rankstatus - Text describing final rank (e.g. "You finished in 3rd place!")
    * closeurl - URL to close/exit the quiz

    Example context (json):
    {
        "quiztitle": "Geography Quiz",
        "rank": 3,
        "rankstatus": "You finished in 3rd place!",
        "closeurl": "/mod/kahoodle/view.php?id=123",
        "avatarurl": "/user/pix.php/2/f1.jpg",
        "displayname": "Alex Johnson"
    }
}}
{{< mod_kahoodle/participant/common/base }}
{{$ main_content }}
{{! Custom header with quiz title instead of question number }}
<div class="mod_kahoodle-participant-result-header">
    <div class="mod_kahoodle-participant-quiz-title">{{quiztitle}}</div>
    <a href="{{closeurl}}" class="mod_kahoodle-participant-close" data-action="close" aria-label="{{#str}}close, mod_kahoodle{{/str}}">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </a>
</div>

<div class="mod_kahoodle-participant-result-content">
    <div class="mod_kahoodle-participant-result-status">{{rankheader}}</div>
    <div class="mod_kahoodle-participant-result-icon mod_kahoodle-result-trophy">
        <img src="{{rankimage}}" alt="">
    </div>
    {{#rankstatus}}
    <div class="mod_kahoodle-participant-result-rank">{{{rankstatus}}}</div>
    {{/rankstatus}}
</div>

{{> mod_kahoodle/participant/common/participantinfo }}
{{/ main_content }}
{{/ mod_kahoodle/participant/common/base }}
