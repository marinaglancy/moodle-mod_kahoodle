{{!
    @template mod_kahoodle/results

    Results page template for Kahoodle activity.

    Context variables required for this template:
    * rounds - array - List of completed rounds with:
        * id - int - Round ID
        * name - string - Round name
        * date - string - Formatted date (without time)
        * lobbyopened - string - Formatted time when lobby opened
        * duration - string - Formatted total round duration
        * participantcount - int - Number of participants
        * averagescore - int - Average score
        * maxscore - int - Maximum score
        * completedcount - int - Number who completed activity
        * participantsurl - string - URL to view participants
        * statisticsurl - string - URL to view statistics

    Example context (json):
    {
        "rounds": [
            {
                "id": 1,
                "name": "Round 1",
                "date": "Monday, 26 January 2026",
                "lobbyopened": "10:00 AM",
                "duration": "25 mins",
                "participantcount": 25,
                "averagescore": 3500,
                "maxscore": 5000,
                "completedcount": 0,
                "participantsurl": "/mod/kahoodle/results.php?roundid=1&view=participants",
                "statisticsurl": "/mod/kahoodle/results.php?roundid=1&view=statistics"
            }
        ]
    }
}}
<div class="mod-kahoodle-results">
    <div class="row">
        {{#rounds}}
        <div class="col-12 col-md-6 col-lg-4 mb-3">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">{{{name}}}</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-6">{{#str}}results_status, mod_kahoodle{{/str}}</dt>
                        <dd class="col-6">{{{status}}}</dd>

                        {{#showdatefields}}
                        <dt class="col-6">{{#str}}results_date, mod_kahoodle{{/str}}</dt>
                        <dd class="col-6">{{{date}}}</dd>
                        <dt class="col-6">{{#str}}results_lobbyopened, mod_kahoodle{{/str}}</dt>
                        <dd class="col-6">{{{lobbyopened}}}</dd>
                        {{/showdatefields}}

                        {{#showfullstats}}
                        <dt class="col-6">{{#str}}results_duration, mod_kahoodle{{/str}}</dt>
                        <dd class="col-6">{{{duration}}}</dd>

                        <dt class="col-6">{{#str}}results_participants, mod_kahoodle{{/str}}</dt>
                        <dd class="col-6">{{{participantcount}}}</dd>
                        <dt class="col-6">{{#str}}results_averagescore, mod_kahoodle{{/str}}</dt>
                        <dd class="col-6">{{{averagescore}}}</dd>

                        <dt class="col-6">{{#str}}results_maxscore, mod_kahoodle{{/str}}</dt>
                        <dd class="col-6">{{{maxscore}}}</dd>

                        <dt class="col-6">{{#str}}results_completed, mod_kahoodle{{/str}}</dt>
                        <dd class="col-6">{{{completedcount}}}</dd>
                        {{/showfullstats}}
                    </dl>
                </div>
                {{#showfullstats}}
                <div class="card-footer">
                    <a href="{{participantsurl}}" class="btn btn-sm btn-outline-primary me-2">
                        {{#str}}results_viewparticipants, mod_kahoodle{{/str}}
                    </a>
                    <a href="{{statisticsurl}}" class="btn btn-sm btn-outline-secondary me-2">
                        {{#str}}results_viewstatistics, mod_kahoodle{{/str}}
                    </a>
                    {{#editquestionsurl}}
                    <a href="{{editquestionsurl}}" class="btn btn-sm btn-outline-secondary">
                        {{#str}}managequestions, mod_kahoodle{{/str}}
                    </a>
                    {{/editquestionsurl}}
                </div>
                {{/showfullstats}}
                {{^showfullstats}}
                {{#editquestionsurl}}
                <div class="card-footer">
                    <a href="{{editquestionsurl}}" class="btn btn-sm btn-outline-secondary">
                        {{#str}}managequestions, mod_kahoodle{{/str}}
                    </a>
                </div>
                {{/editquestionsurl}}
                {{/showfullstats}}
            </div>
        </div>
        {{/rounds}}
    </div>
</div>
