{{!
    @template mod_kahoodle/landing

    Landing page template for Kahoodle activity.

    Context variables required for this template:
    * showcontrolpreparation - bool - Show the control panel for preparation stage
    * startgamebuttondisabled - bool - Whether the start button should be disabled
    * starturl - string - URL for the start action
    * showfacilitatorcontrols - bool - Show facilitator controls when game is in progress
    * finishurl - string - URL for the finish action
    * showparticipantcontrols - bool - Show participant controls when user is playing
    * leaveurl - string - URL for leave action
    * showjoinoption - bool - Show join as participant option
    * joinurl - string - URL for join action
    * showmanagequestions - bool - Show the manage questions section
    * managequestionsurl - string - URL for manage questions page
    * showwaitingtostart - bool - Show waiting message for participants
    * showfinished - bool - Show finished section
    * resultsurl - string - URL for results page

    Example context (json):
    {
        "showcontrolpreparation": true,
        "startgamebuttondisabled": false,
        "starturl": "/mod/kahoodle/view.php?id=1&action=start&sesskey=abc123",
        "showmanagequestions": true,
        "managequestionsurl": "/mod/kahoodle/questions.php?id=1"
    }
}}
<div class="mod-kahoodle-landing">
    {{#showcontrolpreparation}}
    <div class="card mb-3">
        <div class="card-body">
            <p class="card-text">{{#str}}landing_preparation_message, mod_kahoodle{{/str}}</p>
            {{^startgamebuttondisabled}}
            <a href="{{starturl}}" class="btn btn-primary">
                {{#str}}start, mod_kahoodle{{/str}}
            </a>
            {{/startgamebuttondisabled}}
            {{#startgamebuttondisabled}}
            <button type="button" class="btn btn-primary" disabled>
                {{#str}}start, mod_kahoodle{{/str}}
            </button>
            <p class="mt-2 text-muted"><small>{{#str}}start_noquestions, mod_kahoodle{{/str}}</small></p>
            {{/startgamebuttondisabled}}
        </div>
    </div>
    {{/showcontrolpreparation}}

    {{#showfacilitatorcontrols}}
    <div class="card mb-3">
        <div class="card-header">
            <h5 class="mb-0">{{#str}}facilitator_controls, mod_kahoodle{{/str}}</h5>
        </div>
        <div class="card-body">
            <p class="card-text">{{#str}}landing_facilitator_message, mod_kahoodle{{/str}}</p>
            <button type="button" class="btn btn-primary me-2" data-action="resume-game">
                {{#str}}resume_facilitating, mod_kahoodle{{/str}}
            </button>
            <button type="button" class="btn btn-danger" data-action="finish-game" data-finishurl="{{finishurl}}">
                {{#str}}end_round_for_everyone, mod_kahoodle{{/str}}
            </button>
        </div>
    </div>
    {{/showfacilitatorcontrols}}

    {{#showparticipantcontrols}}
    <div class="card mb-3">
        <div class="card-header">
            <h5 class="mb-0">{{#str}}participant_controls, mod_kahoodle{{/str}}</h5>
        </div>
        <div class="card-body">
            <p class="card-text">{{#str}}landing_participant_message, mod_kahoodle{{/str}}</p>
            <button type="button" class="btn btn-primary me-2" data-action="resume-participant">
                {{#str}}resume_playing, mod_kahoodle{{/str}}
            </button>
            {{#leaveurl}}
            <a href="{{leaveurl}}" class="btn btn-outline-secondary">
                {{#str}}join_as_facilitator, mod_kahoodle{{/str}}
            </a>
            {{/leaveurl}}
        </div>
    </div>
    {{/showparticipantcontrols}}

    {{#showjoinoption}}
    <div class="card mb-3">
        <div class="card-body">
            <p class="card-text">{{#str}}landing_join_message, mod_kahoodle{{/str}}</p>
            <a href="{{joinurl}}" class="btn btn-success">
                {{#str}}join_as_participant, mod_kahoodle{{/str}}
            </a>
        </div>
    </div>
    {{/showjoinoption}}

    {{#showmanagequestions}}
    <div class="card mb-3">
        <div class="card-body">
            <p class="card-text">{{#str}}landing_managequestions_message, mod_kahoodle{{/str}}</p>
            <a href="{{managequestionsurl}}" class="btn btn-secondary">
                {{#str}}managequestions, mod_kahoodle{{/str}}
            </a>
        </div>
    </div>
    {{/showmanagequestions}}

    {{#showwaitingtostart}}
    <div class="card mb-3">
        <div class="card-body">
            <p class="card-text">{{#str}}landing_waiting_message, mod_kahoodle{{/str}}</p>
            <p class="card-text">{{#str}}landing_waiting_hint, mod_kahoodle{{/str}}</p>
        </div>
    </div>
    {{/showwaitingtostart}}

    {{#showfinished}}
    <div class="card mb-3">
        <div class="card-body">
            <p class="card-text">{{#str}}landing_finished_message, mod_kahoodle{{/str}}</p>
            <a href="{{resultsurl}}" class="btn btn-primary">
                {{#str}}viewresults, mod_kahoodle{{/str}}
            </a>
        </div>
    </div>
    {{/showfinished}}
</div>
