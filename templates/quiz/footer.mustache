{{!
    @template mod_kahoodle/quiz/footer

    Quiz overlay footer partial with progress bar and controls.

    Context variables required for this template:
    * progresspercent - Percentage of time remaining (0-100)
    * ispaused - Boolean indicating if the quiz is currently paused
    * cancontrol - Boolean indicating if user can control the quiz (teacher)
    * ispreview - Boolean indicating if in preview mode (teacher)


    Example context (json):
    {
        "progresspercent": 65,
        "cancontrol": true,
        "ispreview": true,
        "ispaused": false
    }
}}
<footer class="mod_kahoodle-footer">

    {{! Time progress bar }}
    <div class="mod_kahoodle-progress{{#ispaused}} mod_kahoodle-progress-paused{{/ispaused}}">
        <div class="mod_kahoodle-progress-bar">
            <div class="mod_kahoodle-progress-fill" style="width: {{progresspercent}}%;"></div>
        </div>
    </div>

    {{! Teacher controls }}
    {{#cancontrol}}
    <div class="mod_kahoodle-controls">
        {{#ispreview}}
        <a href="#" class="mod_kahoodle-control-btn" data-action="back">
            {{#pix}}back, mod_kahoodle{{/pix}} {{#str}}back{{/str}}
        </a>
        {{/ispreview}}
        {{^ispaused}}
        <a href="#" class="mod_kahoodle-control-btn" data-action="pause">
            {{#pix}}pause, mod_kahoodle{{/pix}} {{#str}}pause, mod_kahoodle{{/str}}
        </a>
        {{/ispaused}}
        {{#ispaused}}
        <a href="#" class="mod_kahoodle-control-btn" data-action="resume">
            {{#pix}}resume, mod_kahoodle{{/pix}} {{#str}}resume, mod_kahoodle{{/str}}
        </a>
        {{/ispaused}}
        <a href="#" class="mod_kahoodle-control-btn" data-action="next">
            {{#pix}}next, mod_kahoodle{{/pix}} {{#str}}next{{/str}}
        </a>
        <a href="#" class="mod_kahoodle-control-btn" data-action="close">
            {{#pix}}i/window_close, core{{/pix}} {{#str}}close, mod_kahoodle{{/str}}
        </a>
    </div>
    {{/cancontrol}}

</footer>
