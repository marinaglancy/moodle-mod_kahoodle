{{!
    @template mod_kahoodle/quiz/header

    Quiz overlay header partial.

    Context variables required for this template:
    * quiztitle - The title of the quiz/kahoodle activity
    * sortorder - Current question number
    * totalquestions - Total number of questions in the round
}}
<header class="mod_kahoodle-header">
    <div class="mod_kahoodle-quiz-title">{{quiztitle}}</div>
    <div class="mod_kahoodle-question-counter">{{#str}}questioncounter, mod_kahoodle, { "current": "{{sortorder}}", "total": "{{totalquestions}}" }{{/str}}</div>
</header>
