{{!
    @template mod_kahoodle/question_progress

    Question progress display during a quiz round.

    Context variables required for this template:
    * quiztitle - The title of the quiz/kahoodle activity
    * sortorder - Current question number
    * totalquestions - Total number of questions in the round
    * questiontext - The question text to display
    * hasimage - Boolean indicating if question has an image
    * imageurl - URL of the question image (optional)
    * imagelandscape - Boolean indicating if image is landscape orientation
    * imagealt - Alt text for the question image
    * options - Array of answer options, each containing:
        * optionnumber - The option number (1-8)
        * letter - The letter label (A, B, C, etc.)
        * text - The option text
    * optioncount - Number of options (2-8)
    * manyoptions - Boolean indicating if there are more than 4 options
    * progresspercent - Percentage of time remaining (0-100)
    * cancontrol - Boolean indicating if user can control the quiz (teacher)
    * ispreview - Boolean indicating if in preview mode (teacher)
    * ispaused - Boolean indicating if the quiz is currently paused
    * backgroundurl - URL for background image (optional)

    Example context (json):
    {
        "quiztitle": "Geography & World Facts Quiz",
        "sortorder": 36,
        "totalquestions": 42,
        "questiontext": "How long would it take to walk around the world's perimeter?",
        "hasimage": true,
        "imageurl": "https://example.com/globe.jpg",
        "imagelandscape": true,
        "imagealt": "Earth globe",
        "options": [
            {"optionnumber": 1, "letter": "A", "text": "5 days"},
            {"optionnumber": 2, "letter": "B", "text": "50 days"},
            {"optionnumber": 3, "letter": "C", "text": "200 days"},
            {"optionnumber": 4, "letter": "D", "text": "You cannot walk around the world, there is an ocean"}
        ],
        "optioncount": 4,
        "manyoptions": false,
        "progresspercent": 65,
        "cancontrol": true,
        "ispreview": true,
        "ispaused": false
    }
}}
<div class="mod_kahoodle-overlay" {{#backgroundurl}}style="background-image: url('{{backgroundurl}}');"{{/backgroundurl}}>

    {{> mod_kahoodle/quiz/header }}

    {{! Main content: Question, image, and options }}
    <main class="mod_kahoodle-main">

        {{! Question text }}
        <div class="mod_kahoodle-question">
            <h1 class="mod_kahoodle-question-text">{{{questiontext}}}</h1>
        </div>

        {{! Question image }}
        {{#hasimage}}
        <div class="mod_kahoodle-image-container">
            <img src="{{imageurl}}" alt="{{imagealt}}" class="mod_kahoodle-image{{#imagelandscape}} mod_kahoodle-image-landscape{{/imagelandscape}}">
        </div>
        {{/hasimage}}

        {{! Answer options }}
        <div class="mod_kahoodle-options{{#manyoptions}} mod_kahoodle-options-many{{/manyoptions}}">
            <div class="mod_kahoodle-options-grid{{#manyoptions}} mod_kahoodle-options-grid-compact{{/manyoptions}}">
                {{#options}}
                <div class="mod_kahoodle-option mod_kahoodle-option{{optionnumber}}" data-option="{{optionnumber}}">
                    <div class="mod_kahoodle-option-icon">
                        <span class="mod_kahoodle-icon-letter">{{letter}}</span>
                    </div>
                    <span class="mod_kahoodle-option-text">{{text}}</span>
                </div>
                {{/options}}
            </div>
        </div>

    </main>

    {{> mod_kahoodle/quiz/footer }}

</div>
